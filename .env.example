# VITE_GOOGLE_CLIENT_ID: Your Google OAuth 2.0 Client ID for the frontend.
VITE_GOOGLE_CLIENT_ID=

# OPENCODE_API_KEY: The API key for OpenCode Zen (baseURL: https://opencode.ai/zen/v1).
OPENCODE_API_KEY=

# GOOGLE_CLIENT_ID: Google OAuth Client ID for the backend googleapis integration.
GOOGLE_CLIENT_ID=

# GOOGLE_CLIENT_SECRET: Google OAuth Client Secret for the backend googleapis integration.
GOOGLE_CLIENT_SECRET=

# SESSION_SECRET: A secret string for signing session cookies.
SESSION_SECRET=super-secret-zen-key
